{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/Service/food-delivery-management/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/Service/food-delivery-management/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/Service/food-delivery-management",
  "projects": {
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "driver-service": {
      "type": "application",
      "root": "apps/driver-service",
      "entryFile": "main",
      "sourceRoot": "apps/driver-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/driver-service/tsconfig.app.json"
      }
    },
    "food-delivery-management": {
      "type": "application",
      "root": "apps/Service/food-delivery-management",
      "entryFile": "main",
      "sourceRoot": "apps/Service/food-delivery-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/Service/food-delivery-management/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "order-service": {
      "type": "application",
      "root": "apps/order-service",
      "entryFile": "main",
      "sourceRoot": "apps/order-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/order-service/tsconfig.app.json"
      }
    },
    "payment-service": {
      "type": "application",
      "root": "apps/payment-service",
      "entryFile": "main",
      "sourceRoot": "apps/payment-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment-service/tsconfig.app.json"
      }
    },
    "restaurant-service": {
      "type": "application",
      "root": "apps/restaurant-service",
      "entryFile": "main",
      "sourceRoot": "apps/restaurant-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/restaurant-service/tsconfig.app.json"
      }
    },
    "review-service": {
      "type": "application",
      "root": "apps/review-service",
      "entryFile": "main",
      "sourceRoot": "apps/review-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/review-service/tsconfig.app.json"
      }
