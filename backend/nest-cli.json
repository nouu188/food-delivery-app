      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "shared-dtos": {
      "type": "library",
      "root": "libs/shared-dtos",
      "entryFile": "index",
      "sourceRoot": "libs/shared-dtos/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared-dtos/tsconfig.lib.json"
      }
    },
    "user": {
      "type": "application",
      "root": "apps/Service/user",
      "entryFile": "main",
      "sourceRoot": "apps/Service/user/src",
      "compilerOptions": {
        "tsConfigPath": "apps/Service/user/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
